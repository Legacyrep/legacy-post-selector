{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "shell": "bash",
            "command": "bash .claude/hooks/auto-push-legacy.sh",
            "timeout": 60,
            "statusMessage": "Auto-pushing legacy_post_selector.html to GitHub..."
          }
        ]
      }
    ]
  }
}
